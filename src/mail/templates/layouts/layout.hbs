{{!-- Layout --}}
{{!-- src\mail\templates\layouts\layout.hbs --}}
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Novo Cars</title>
  </head>

  <body style="margin:0; padding:0; background:#f2f4f7; font-family: Arial, Helvetica, sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f2f4f7; padding:40px 0;">
      <tr>
        <td align="center">

          <!-- MAIN CONTAINER -->
          <table width="620" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.05);">

            <!-- HEADER -->
            <tr>
              <td style="background:#0b1c2d; padding:30px; text-align:center;">

                <!-- 🔵 Replace this URL with your Cloudinary logo -->
                <!-- Example: https://res.cloudinary.com/your-cloud-name/image/upload/v123/logo.png -->
                <img 
                  src="https://res.cloudinary.com/djogptxxc/image/upload/v1756452872/novo-logo-b_jvxbx0.png"
                  alt="Novo Cars"
                  width="150"
                  style="display:block; margin:0 auto 15px auto;"
                />

                <h1 style="color:#ffffff; margin:0; font-size:22px; letter-spacing:1px;">
                  NOVO CARS
                </h1>

                <p style="color:#cbd5e1; font-size:13px; margin-top:8px;">
                  Executive Travel & Fleet Solutions
                </p>

              </td>
            </tr>

            <!-- BODY CONTENT -->
            <tr>
              <td style="padding:40px 35px; color:#1f2937; font-size:15px; line-height:1.6;">
               {{{body}}}
              </td>
            </tr>

            <!-- DIVIDER -->
            <tr>
              <td style="padding:0 35px;">
                <hr style="border:none; border-top:1px solid #e5e7eb;" />
              </td>
            </tr>

            <!-- FOOTER -->
            <tr>
              <td style="padding:30px 35px; text-align:center;">

                <!-- SOCIAL ICONS -->
                <div style="margin-bottom:20px;">

                  <!-- Facebook -->
                  <a href="https://facebook.com/novocars" style="margin:0 8px;">
                    <img 
                      src="https://cdn-icons-png.flaticon.com/512/733/733547.png"
                      width="22"
                      alt="Facebook"
                      style="vertical-align:middle;"
                    />
                  </a>

                  <!-- Instagram -->
                  <a href="https://instagram.com/novocars" style="margin:0 8px;">
                    <img 
                      src="https://cdn-icons-png.flaticon.com/512/2111/2111463.png"
                      width="22"
                      alt="Instagram"
                      style="vertical-align:middle;"
                    />
                  </a>

                  <!-- YouTube -->
                  <a href="https://youtube.com/@novocars" style="margin:0 8px;">
                    <img 
                      src="https://cdn-icons-png.flaticon.com/512/1384/1384060.png"
                      width="22"
                      alt="YouTube"
                      style="vertical-align:middle;"
                    />
                  </a>

                  <!-- X (Twitter) -->
                  <a href="https://x.com/novocars" style="margin:0 8px;">
                    <img 
                      src="https://cdn-icons-png.flaticon.com/512/5968/5968830.png"
                      width="22"
                      alt="X"
                      style="vertical-align:middle;"
                    />
                  </a>

                </div>

                <p style="font-size:12px; color:#6b7280; margin:0;">
                  © {{year}} Novo Cars. All rights reserved.
                </p>

                <p style="font-size:12px; color:#9ca3af; margin-top:8px;">
                  Professional Executive Transport & Fleet Management Services
                </p>

              </td>
            </tr>

          </table>
          <!-- END CONTAINER -->

        </td>
      </tr>
    </table>

  </body>
</html>