<h2>🚚 New Fleet Booking Request</h2>

<p>A new fleet booking has been submitted. Details below:</p>

<hr/>

<h3>👤 Customer Details</h3>
<p><strong>Name:</strong> {{name}}</p>
<p><strong>Email:</strong> {{email}}</p>
<p><strong>Phone:</strong> {{phone}}</p>

<hr/>

<h3>📍 Trip Details</h3>
<p><strong>Pickup Location:</strong> {{pickup}}</p>
<p><strong>Destination:</strong> {{destination}}</p>
<p><strong>Date:</strong> {{date}}</p>
<p><strong>Time:</strong> {{time}}</p>

<hr/>

<h3>🚛 Booking Details</h3>
<p><strong>Passenger Count:</strong> {{passengerCount}}</p>

{{#if vehicleType}}
  <p><strong>Vehicle Type:</strong> {{vehicleType}}</p>
{{else}}
  <p><strong>Vehicle Type:</strong> Not specified</p>
{{/if}}

{{#if vehicleName}}
  <p><strong>Selected Vehicle:</strong> {{vehicleName}}</p>
{{/if}}

{{#if cargoDescription}}
  <p><strong>Cargo Description:</strong> {{cargoDescription}}</p>
{{/if}}

{{#if specialRequests}}
  <p><strong>Special Requests:</strong></p>
  <p>{{specialRequests}}</p>
{{/if}}

<hr/>

<p style="font-size: 12px; color: #666;">
  This request was submitted via Novo Fleet Management system.
</p>