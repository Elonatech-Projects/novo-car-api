<h2>New Airport Transfer Booking</h2>

<ul>
  <li><strong>Name:</strong> {{name}}</li>
  <li><strong>Email:</strong> {{email}}</li>
  <li><strong>Phone:</strong> {{phone}}</li>
  <li><strong>Airport:</strong> {{airport}}</li>
  <li><strong>Terminal:</strong> {{terminal}}</li>
  <li><strong>Pick-up Location:</strong> {{default pickupLocation "Not provided"}}</li>
  <li><strong>Drop-off Location:</strong> {{default dropoffLocation "Not provided"}}</li>
  <li><strong>Date:</strong> {{formatDate date}}</li>
  <li><strong>Time:</strong> {{default pickupTime "Not provided"}}</li>
  <li><strong>Vehicle:</strong> {{vehicle}}</li>
  <li><strong>Category:</strong> {{default category "Not provided"}}</li>
  <li><strong>Notes / Special Requests:</strong> {{default notes "None"}}</li>
</ul>